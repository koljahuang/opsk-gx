apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: backend-secrets
  namespace: opsk
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: aws-secrets-manager
    kind: ClusterSecretStore
  target:
    name: backend-secrets
    creationPolicy: Owner
  data:
  - secretKey: database-url
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: database-url
  - secretKey: jwt-secret
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: jwt-secret-key
  - secretKey: microsoft-client-id
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: microsoft-client-id
  - secretKey: microsoft-client-secret
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: microsoft-client-secret
  - secretKey: microsoft-tenant-id
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: microsoft-tenant-id
  - secretKey: cognito-user-pool-id
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: cognito-user-pool-id
  - secretKey: cognito-client-id
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: cognito-client-id
  - secretKey: cognito-client-secret
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: cognito-client-secret
  - secretKey: cognito-region
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: cognito-region
  # Grafana Cloud
  - secretKey: grafana-cloud-metrics-username
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: grafana-cloud-metrics-username
  - secretKey: grafana-cloud-logs-username
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: grafana-cloud-logs-username
  - secretKey: grafana-cloud-traces-username
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: grafana-cloud-traces-username
  - secretKey: grafana-cloud-api-token
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: grafana-cloud-api-token
  # AI/LLM
  - secretKey: anthropic-api-key
    remoteRef:
      key: ${SECRETS_MANAGER_NAME}
      property: anthropic-api-key
