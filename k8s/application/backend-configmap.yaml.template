apiVersion: v1
kind: ConfigMap
metadata:
  name: backend-config
  namespace: opsk
data:
  # ── Environment ──────────────────────────────
  OPS_ENV: "${DEPLOY_ENV}"
  BACKEND_PORT: "3080"
  RUST_LOG: "opsk=info,tower_http=info"

  # ── Database ─────────────────────────────────
  # DATABASE_URL comes from Secret (ESO)
  DB_MAX_CONNECTIONS: "20"
  DB_MIN_CONNECTIONS: "5"

  # ── CORS ─────────────────────────────────────
  ALLOWED_ORIGINS: "https://${FRONTEND_DOMAIN}"

  # ── Claude Code ──────────────────────────────
  CLAUDE_TIMEOUT_MS: "300000"
  CLAUDE_MODEL: "opus"
  CLAUDE_WORK_DIR: "/app/workspace"

  # ── Cognito ──────────────────────────────────
  COGNITO_DOMAIN: "${COGNITO_DOMAIN}"
  COGNITO_REDIRECT_URIS: "https://${FRONTEND_DOMAIN}/auth/cognito/callback"
  MICROSOFT_REDIRECT_URIS: "https://${FRONTEND_DOMAIN}/auth/microsoft/callback"

  # ── Claude Code ──────────────────────────────
  DISABLE_LOGIN_COMMAND: "1"

  # ── Public API URL (for external callbacks) ──
  PUBLIC_API_URL: "https://${API_DOMAIN}"

  # ── AWS ──────────────────────────────────────
  AWS_REGION: "${AWS_REGION}"
