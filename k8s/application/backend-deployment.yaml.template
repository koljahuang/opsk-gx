apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: opsk
  labels:
    app: backend
spec:
  replicas: 2
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      serviceAccountName: backend
      nodeSelector:
        karpenter.sh/nodepool: common-nodepool
      containers:
      - name: backend
        image: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/opsk-backend:latest
        ports:
        - containerPort: 3080
          protocol: TCP
        envFrom:
        - configMapRef:
            name: backend-config
        env:
        - name: DATABASE_URL
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: database-url
        - name: JWT_SECRET
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: jwt-secret
        - name: COGNITO_USER_POOL_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-user-pool-id
        - name: COGNITO_CLIENT_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-client-id
        - name: COGNITO_CLIENT_SECRET
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-client-secret
        - name: COGNITO_REGION
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-region
        - name: MICROSOFT_CLIENT_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: microsoft-client-id
              optional: true
        - name: MICROSOFT_CLIENT_SECRET
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: microsoft-client-secret
              optional: true
        - name: MICROSOFT_TENANT_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: microsoft-tenant-id
              optional: true
        volumeMounts:
        - name: workspace
          mountPath: /app/workspace
        livenessProbe:
          httpGet:
            path: /health
            port: 3080
          initialDelaySeconds: 60
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health
            port: 3080
          initialDelaySeconds: 30
          periodSeconds: 10
          timeoutSeconds: 3
          failureThreshold: 2
        resources:
          requests:
            cpu: "${BACKEND_CPU_REQUEST}"
            memory: "${BACKEND_MEMORY_REQUEST}"
          limits:
            cpu: "${BACKEND_CPU_LIMIT}"
            memory: "${BACKEND_MEMORY_LIMIT}"
      volumes:
      - name: workspace
        persistentVolumeClaim:
          claimName: backend-workspace
