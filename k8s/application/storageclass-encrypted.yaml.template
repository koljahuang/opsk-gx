---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: efs-workspace
provisioner: efs.csi.aws.com
parameters:
  provisioningMode: efs-ap
  fileSystemId: "${EFS_FILESYSTEM_ID}"
  directoryPerms: "700"
  basePath: "/workspace"
  uid: "0"
  gid: "0"
reclaimPolicy: Retain
volumeBindingMode: Immediate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: backend-workspace
  namespace: opsk
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: efs-workspace
  resources:
    requests:
      storage: 50Gi
