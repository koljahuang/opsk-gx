# Environment files (secrets must not be baked into images)
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
!*.env.example
!*/.env.example

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# Build artifacts
backend/target
frontend/node_modules
frontend/.nuxt
frontend/.output

# Infrastructure (not needed in app images)
iac/
k8s/
.github/
docs/

# Development / tooling
.claude/
scripts/
*.md
LICENSE
docker-compose.yml

# Allow .opsk/screener (needed by backend build)
!.opsk/
