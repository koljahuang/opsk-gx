# ============================================================
# Ops Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Environment: local / dev / prod
OPS_ENV=local

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://opsk:opsk_dev@localhost:5432/opsk
# Pool settings (optional, defaults shown)
# DB_MAX_CONNECTIONS=20
# DB_MIN_CONNECTIONS=5

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=dev-secret-minimum-32-characters-long-change-in-prod

# ── Server ────────────────────────────────────────────────────
BACKEND_PORT=3080
FRONTEND_PORT=3000

# ── CORS ──────────────────────────────────────────────────────
# local: http://localhost:3000
# prod: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Claude Code ───────────────────────────────────────────────
CLAUDE_TIMEOUT_MS=300000
CLAUDE_MODEL=opus
CLAUDE_WORK_DIR=./workspace

# ── AWS (local dev uses profile, prod uses IAM role) ──────────
AWS_PROFILE=default
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── SSE Direct Connect ────────────────────────────────────────
# Frontend SSE streams bypass Nitro proxy and connect directly to backend.
# Local: point to backend port. Prod: leave empty (ingress handles routing).
NUXT_PUBLIC_SSE_BASE=http://localhost:3080

# ── Logging ───────────────────────────────────────────────────
RUST_LOG=opsk=debug,tower_http=debug
